terraform_starter\terraform\modules\ec2\terraform.auto.tfvars.example
```
# Example terraform.auto.tfvars for EC2 module

# Name of the application (used for tagging and resource naming)
application_name = "example-app"

# Name of the environment (must be <= 8 chars, alphanumeric and hyphens only)
environment = "dev"

# Name of the EC2 instance
instance_name = "web-server"

# The AMI to use for the instance
ami = "ami-0123456789abcdef0"

# The public key to use for the instance (SSH format)
public_key = "ssh-rsa  admin@server.local"

# The ID of the private subnet
private_subnet_id = "subnet-abc123"

# The instance profile to use for the instance
ec2_instance_profile = "my-instance-profile"

# The security group to use for the instance
sg_id = "sg-0123456789abcdef0"

# The size of the volume in GB
volume_size = 16

# The user data to use for the instance (optional)
user_data = ""

# Whether to create the EC2 instance
create_ec2_instance = true
